{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Ingester",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/ingester.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Streaming job",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/streaming_job.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Streamlit dashboard",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "${workspaceFolder}/app.py"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
